{
  "openapi": "3.0.0",
  "info": {
    "title": "Paxos Rewards API",
    "version": "v2-preview"
  },
  "paths": {
    "/rewards/addresses": {
      "get": {
        "summary": "List reward addresses",
        "description": "Returns a paginated list of reward addresses",
        "operationId": "ListAttributionAddresses",
        "tags": ["Reward Addresses"],
        "security": [
          {
            "OAuth2": ["rewards:read_monitoring_address"]
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "format": "int32" }
          },
          {
            "name": "ledger",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["ETHEREUM", "SOLANA", "INK", "XLAYER", "ARBITRUM_ONE"]
            }
          },
          {
            "name": "address",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "order",
            "description": "Optional, sort order for results based on created_at. The default sort order is DESC.",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["DESC", "ASC"] }
          },
          {
            "name": "page_cursor",
            "description": "Optional, cursor token for fetching the next page.",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "id",
            "description": "Optional, address id.",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "payout_group_id",
            "description": "Optional, filter by payout group.",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "include_balance",
            "description": "When true, fetch and include balance for each address.",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean" }
          },
          {
            "name": "balance_timestamp",
            "description": "Point-in-time for balance query (optional, defaults to now).",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "format": "date-time" }
          }
        ],
        "responses": {
          "200": {
            "description": "A successful response.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListAttributionAddressesResponse" }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a reward address",
        "description": "Creates a new reward address for reward attribution.",
        "operationId": "CreateAttributionAddress",
        "tags": ["Reward Addresses"],
        "security": [
          {
            "OAuth2": ["rewards:write_monitoring_address"]
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateAttributionAddressRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A successful response.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateAttributionAddressResponse" }
              }
            }
          }
        }
      }
    },
    "/rewards/addresses/{id}": {
      "put": {
        "summary": "Update a reward address",
        "description": "Updates an existing reward address.",
        "operationId": "UpdateAttributionAddress",
        "tags": ["Reward Addresses"],
        "security": [
          {
            "OAuth2": ["rewards:write_monitoring_address"]
          }
        ],
        "parameters": [
          {
            "name": "id",
            "description": "Address ID used as the URL path parameter. Must match address.id when both are provided.",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateAttributionAddressBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A successful response.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UpdateAttributionAddressResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete a reward address",
        "description": "Deletes a reward address.",
        "operationId": "DeleteAttributionAddress",
        "tags": ["Reward Addresses"],
        "security": [
          {
            "OAuth2": ["rewards:write_monitoring_address"]
          }
        ],
        "parameters": [
          {
            "name": "id",
            "description": "Address ID to delete.",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "A successful response.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeleteAttributionAddressResponse" }
              }
            }
          }
        }
      }
    },
    "/rewards/claim-schedules": {
      "get": {
        "summary": "List claim schedules",
        "description": "Returns a paginated list of claim schedules.",
        "operationId": "ListClaimSchedules",
        "tags": ["Claims"],
        "security": [
          {
            "OAuth2": ["rewards:read_claims_schedule"]
          }
        ],
        "parameters": [
          {
            "name": "payout_group_id",
            "description": "Optionally filter by payout group.",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "description": "Number of results to return. Defaults to 100. Maximum 1000.",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "format": "int32" }
          },
          {
            "name": "page_cursor",
            "description": "Cursor for getting the next page of results.",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "A successful response.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListClaimSchedulesResponse" }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a claim schedule",
        "description": "Creates a new claim schedule for automatic reward claims.",
        "operationId": "CreateClaimSchedule",
        "tags": ["Claims"],
        "security": [
          {
            "OAuth2": ["rewards:write_claims_schedule"]
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateClaimScheduleRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A successful response.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateClaimScheduleResponse" }
              }
            }
          }
        }
      }
    },
    "/rewards/claim-schedules/{id}": {
      "put": {
        "summary": "Update a claim schedule",
        "description": "Updates an existing claim schedule.",
        "operationId": "UpdateClaimSchedule",
        "tags": ["Claims"],
        "security": [
          {
            "OAuth2": ["rewards:write_claims_schedule"]
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ClaimServicePublicUpdateClaimScheduleBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A successful response.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UpdateClaimScheduleResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete a claim schedule",
        "description": "Deletes a claim schedule.",
        "operationId": "DeleteClaimSchedule",
        "tags": ["Claims"],
        "security": [
          {
            "OAuth2": ["rewards:write_claims_schedule"]
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "A successful response.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeleteClaimScheduleResponse" }
              }
            }
          }
        }
      }
    },
    "/rewards/claims": {
      "get": {
        "summary": "List claims",
        "description": "Returns a paginated list of claims with optional filtering.",
        "operationId": "ListClaims",
        "tags": ["Claims"],
        "security": [
          {
            "OAuth2": ["rewards:read_claims"]
          }
        ],
        "parameters": [
          {
            "name": "payout_group_id",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "onchain_statuses",
            "description": "Filter by onchain_status values.",
            "in": "query",
            "required": false,
            "explode": true,
            "schema": {
              "type": "array",
              "items": { "$ref": "#/components/schemas/ClaimOnchainStatus" }
            }
          },
          {
            "name": "chain",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "jurisdiction",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "start_time",
            "description": "Start time filter (inclusive).",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "end_time",
            "description": "End time filter (inclusive).",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "format": "int32" }
          },
          {
            "name": "page_cursor",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "A successful response.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListClaimsResponse" }
              }
            }
          }
        }
      }
    },
    "/rewards/payout-groups": {
      "get": {
        "summary": "List Payout Groups",
        "description": "Retrieves a list of payout groups.",
        "operationId": "ListPayoutGroups",
        "tags": ["Payout Groups"],
        "security": [
          {
            "OAuth2": ["rewards:read_payout_groups"]
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "format": "int32" }
          },
          {
            "name": "page_cursor",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "A successful response.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListPayoutGroupsResponse" }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create Payout Group",
        "description": "Adds a payout group. A payout group encapsulates common rewards characteristics. All monitored addresses which reference this payout group will accumulate rewards at the same rate and claim their rewards to the payout destination specified for this group.",
        "operationId": "CreatePayoutGroup",
        "tags": ["Payout Groups"],
        "security": [
          {
            "OAuth2": ["rewards:write_payout_groups"]
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreatePayoutGroupRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A successful response.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreatePayoutGroupResponse" }
              }
            }
          }
        }
      }
    },
    "/rewards/payout-groups/{id}": {
      "put": {
        "summary": "Update Payout Group",
        "description": "Updates a payout group. Any changes to a payout group which has an on-chain component will cause the unclaimed rewards for that group to be implicitly claimed. No details of the implicit claiming are returned in this API response.",
        "operationId": "UpdatePayoutGroup",
        "tags": ["Payout Groups"],
        "security": [
          {
            "OAuth2": ["rewards:write_payout_groups"]
          }
        ],
        "parameters": [
          {
            "name": "id",
            "description": "UUID direct reference to the existing payout group.",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RewardsPayoutGroupServiceUpdatePayoutGroupBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A successful response.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UpdatePayoutGroupResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete Payout Group",
        "description": "Deletes a payout group. Deleting a payout group which has an on-chain component will cause the unclaimed rewards for that group to be implicitly claimed. No details of the implicit claiming are returned in this API response.",
        "operationId": "DeletePayoutGroup",
        "tags": ["Payout Groups"],
        "security": [
          {
            "OAuth2": ["rewards:write_payout_groups"]
          }
        ],
        "parameters": [
          {
            "name": "id",
            "description": "UUID direct reference to the payout group to delete.",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "A successful response.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeletePayoutGroupResponse" }
              }
            }
          }
        }
      }
    },
    "/rewards/details": {
      "get": {
        "summary": "Get reward details",
        "description": "Returns current reward rates, next accrual time, lifetime earned, and total available rewards.",
        "operationId": "GetRewardDetails",
        "tags": ["Rewards"],
        "security": [
          {
            "OAuth2": ["rewards:read_rewards_details"]
          }
        ],
        "responses": {
          "200": {
            "description": "A successful response.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GetRewardDetailsResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "OAuth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://oauth.paxos.com/oauth2/token",
            "scopes": {
              "rewards:read_monitoring_address": "Read reward addresses",
              "rewards:write_monitoring_address": "Create and manage reward addresses",
              "rewards:read_claims_schedule": "Read claim schedules",
              "rewards:write_claims_schedule": "Create and manage claim schedules",
              "rewards:read_claims": "Read claims",
              "rewards:read_payout_groups": "Read payout groups",
              "rewards:write_payout_groups": "Create and manage payout groups",
              "rewards:read_rewards_details": "Read reward details"
            }
          }
        }
      }
    },
    "schemas": {
      "AttributionLedgerType": {
        "type": "string",
        "enum": ["ETHEREUM", "SOLANA", "INK", "XLAYER", "ARBITRUM_ONE"],
        "example": "ETHEREUM",
        "description": "An AttributionLedgerType is a data source which produces events which cause monitoring to occur. Examples include blockchains and the Paxos platform."
      },
      "AttributionAddress": {
        "type": "object",
        "title": "All data associated with an attribution address",
        "properties": {
          "id": {
            "type": "string",
            "readOnly": true,
            "description": "Address ID. Auto-generated."
          },
          "ledger": {
            "$ref": "#/components/schemas/AttributionLedgerType"
          },
          "address": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "payout_group_id": {
            "type": "string",
            "description": "UUID of the payout group this address belongs to."
          },
          "balance": {
            "type": "string",
            "readOnly": true,
            "description": "Total custody at address. Only populated when include_balance=true in request."
          },
          "status": {
            "type": "string",
            "readOnly": true,
            "description": "Output only. Registration status (UNREGISTERED, PENDING, ACTIVE, FAILED). Server-managed."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          }
        }
      },
      "CreateAttributionAddressBody": {
        "type": "object",
        "required": ["ledger", "address"],
        "properties": {
          "ledger": {
            "$ref": "#/components/schemas/AttributionLedgerType"
          },
          "address": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "payout_group_id": {
            "type": "string",
            "description": "UUID of the payout group this address belongs to."
          }
        }
      },
      "UpdateAttributionAddressBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "payout_group_id": {
            "type": "string",
            "description": "UUID of the payout group this address belongs to."
          }
        }
      },
      "ListAttributionAddressesResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AttributionAddress" },
            "description": "Monitored addresses in this page of results."
          },
          "next_page_cursor": {
            "type": "string",
            "description": "Token for the next page of results; empty if no more results."
          }
        }
      },
      "CreateAttributionAddressRequest": {
        "type": "object",
        "required": ["address"],
        "properties": {
          "address": { "$ref": "#/components/schemas/CreateAttributionAddressBody" }
        }
      },
      "CreateAttributionAddressResponse": {
        "type": "object",
        "properties": {
          "address": { "$ref": "#/components/schemas/AttributionAddress" }
        }
      },
      "UpdateAttributionAddressResponse": {
        "type": "object",
        "properties": {
          "address": { "$ref": "#/components/schemas/AttributionAddress" }
        }
      },
      "DeleteAttributionAddressResponse": {
        "type": "object"
      },
      "ScheduleType": {
        "type": "string",
        "enum": ["DAILY"]
      },
      "ClaimSchedule": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "payout_group_id": { "type": "string" },
          "schedule_type": { "$ref": "#/components/schemas/ScheduleType" },
          "next_run_at": { "type": "string", "format": "date-time" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "ListClaimSchedulesResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ClaimSchedule" },
            "description": "Claim schedules in this page of results."
          },
          "next_page_cursor": {
            "type": "string",
            "description": "Token to retrieve the next page of results, or empty if there are no more results."
          }
        }
      },
      "CreateClaimScheduleRequest": {
        "type": "object",
        "required": ["payout_group_id", "schedule_type"],
        "properties": {
          "payout_group_id": { "type": "string" },
          "schedule_type": { "$ref": "#/components/schemas/ScheduleType" }
        }
      },
      "CreateClaimScheduleResponse": {
        "type": "object",
        "properties": {
          "claim_schedule": { "$ref": "#/components/schemas/ClaimSchedule" }
        }
      },
      "ClaimServicePublicUpdateClaimScheduleBody": {
        "type": "object",
        "required": ["schedule_type"],
        "properties": {
          "schedule_type": { "$ref": "#/components/schemas/ScheduleType" }
        }
      },
      "UpdateClaimScheduleResponse": {
        "type": "object",
        "properties": {
          "claim_schedule": { "$ref": "#/components/schemas/ClaimSchedule" }
        }
      },
      "DeleteClaimScheduleResponse": {
        "type": "object"
      },
      "ClaimType": {
        "type": "string",
        "enum": ["CLAIM_ALL", "CLAIM_FOR_ADDRESSES"]
      },
      "ClaimOnchainStatus": {
        "type": "string",
        "enum": ["PENDING", "SUBMITTED", "CONFIRMED", "FAILED"]
      },
      "Claim": {
        "type": "object",
        "title": "A reward claim transaction",
        "properties": {
          "id": { "type": "string" },
          "payout_group_id": { "type": "string" },
          "claim_type": { "$ref": "#/components/schemas/ClaimType" },
          "claim_schedule_id": {
            "type": "string",
            "description": "Present if triggered by a schedule."
          },
          "onchain_status": { "$ref": "#/components/schemas/ClaimOnchainStatus" },
          "amount": {
            "type": "string",
            "description": "Amount in business units (e.g., \"123.456789\" for USDG)."
          },
          "tx_hash": { "type": "string" },
          "addresses": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Populated for CLAIM_FOR_ADDRESSES type."
          },
          "error_message": { "type": "string" },
          "blockchain": { "type": "string" },
          "asset_type": { "type": "string" },
          "submitted_at": { "type": "string", "format": "date-time" },
          "confirmed_at": { "type": "string", "format": "date-time" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "ListClaimsResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Claim" },
            "description": "Claims in this page of results."
          },
          "next_page_cursor": {
            "type": "string",
            "description": "Token to retrieve the next page of results, or empty if there are no more results."
          }
        }
      },
      "PayoutGroup": {
        "type": "object",
        "required": ["id", "ledger", "asset_type", "rate_id", "jurisdiction", "claimer_address", "onchain_status", "balance", "created_at", "updated_at"],
        "properties": {
          "id": {
            "type": "string",
            "description": "UUID direct reference to the created payout group."
          },
          "ledger": { "type": "string", "description": "Ledger identifier." },
          "asset_type": { "type": "string", "description": "Asset type for this payout group." },
          "rate_id": { "type": "string", "description": "Rate ID associated with this payout group." },
          "jurisdiction": { "type": "string", "description": "Jurisdiction for this payout group." },
          "name": { "type": "string", "description": "User-readable name for this group." },
          "claimer_address": { "type": "string", "description": "Address with signing authority to claim rewards for this group." },
          "manager_address": { "type": "string", "description": "Address that manages this payout group. Defaults to claimer_address if not explicitly set." },
          "destination_address": { "type": "string", "description": "Address that receives reward payouts for this group. Defaults to claimer_address if not explicitly set." },
          "onchain_group_id": { "type": "string", "format": "int64", "description": "On-chain group ID (optional)." },
